{
  "name": "randomwalk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/signalwerk.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "npm run build:client && npm run build:ssr && node scripts/prerender.mjs",
    "build:client": "vite build --outDir dist",
    "build:ssr": "vite build --ssr src/entry-server.tsx --outDir dist-ssr",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "signalwerk.md": "file:packages/signalwerk.md"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^18.2.79",
    "@types/react-dom": "^18.2.25",
    "@vitejs/plugin-react": "^5.0.0",
    "sass": "^1.89.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  }
}
